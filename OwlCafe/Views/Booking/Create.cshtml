@model OwlCafe.DTOs.BookingDto

@{
    ViewData["Title"] = "Book a Table - Owl Cafe";
}

<!-- Booking Hero -->
<section class="hero" style="height: 50vh; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);">
    <div class="hero-content">
        <h1 class="text-accent">Reserve Your Table</h1>
        <p class="subtitle">Join Us for an Unforgettable Experience</p>
    </div>
</section>

<!-- Booking Form -->
<section class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-card">
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Count > 0)
                {
                    <div class="alert alert-danger">
                        <ul>
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                @foreach (var error in modelState.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <h3 class="mb-4">Booking Details</h3>
                <p class="mb-4">Already booked? <a href="@Url.Action("Status", "Booking")">Check your booking status</a>.</p>

                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="CustomerName">Full Name</label>
                                <input type="text" class="form-control" id="CustomerName" name="CustomerName" value="@Model?.CustomerName" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Email">Email</label>
                                <input type="email" class="form-control" id="Email" name="Email" value="@Model?.Email" required>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Phone">Phone Number</label>
                                <input type="tel" class="form-control" id="Phone" name="Phone" value="@Model?.Phone" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Guests">Number of Guests</label>
                                <input type="number" class="form-control" id="Guests" name="Guests" min="1" max="20" value="@(Model?.Guests > 0 ? Model.Guests : 1)" required>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="BookingDate">Booking Date</label>
                                <input type="date" class="form-control" id="BookingDate" name="BookingDate" value="@Model?.BookingDate.ToString("yyyy-MM-dd")" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="BookingTime">Booking Time</label>
                                <input type="time" class="form-control" id="BookingTime" name="BookingTime" value="@Model?.BookingTime.ToString("hh\\:mm")" required>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="SpecialRequest">Special Request (Optional)</label>
                        <textarea class="form-control" id="SpecialRequest" name="SpecialRequest" rows="3">@Model?.SpecialRequest</textarea>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100">Confirm Booking</button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Info Section -->
<section class="container py-5">
    <div class="row">
        <div class="col-md-4 text-center mb-4">
            <i class="fas fa-check-circle fa-3x text-accent mb-3"></i>
            <h5>Instant Confirmation</h5>
            <p>Receive immediate confirmation of your reservation</p>
        </div>
        <div class="col-md-4 text-center mb-4">
            <i class="fas fa-calendar-alt fa-3x text-accent mb-3"></i>
            <h5>Flexible Scheduling</h5>
            <p>Choose your preferred date and time</p>
        </div>
        <div class="col-md-4 text-center mb-4">
            <i class="fas fa-headset fa-3x text-accent mb-3"></i>
            <h5>24/7 Support</h5>
            <p>Contact us anytime for assistance</p>
        </div>
    </div>
</section>
