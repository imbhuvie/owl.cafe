@{
    ViewData["Title"] = "About - Owl Cafe";
}

<!-- About Hero -->
<section class="hero" style="height: 50vh; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);">
    <div class="hero-content">
        <h1 class="text-accent">About Us</h1>
        <p class="subtitle">Discover Our Story</p>
    </div>
</section>

<!-- About Content -->
<section class="container py-5">
    <div class="row">
        <div class="col-md-6 mb-4">
            <h2 class="mb-3">Our Story</h2>
            <p>Founded in 2015, Owl Cafe has been serving the finest culinary experiences to our valued guests. What started as a small cafe has grown into a premier dining destination, known for exceptional food, outstanding service, and an elegant ambiance.</p>
            <p>Our commitment to excellence drives every decision we make, from sourcing the finest ingredients to training our dedicated staff.</p>
        </div>
        <div class="col-md-6 mb-4">
            <img src="/images/about-placeholder.jpg" alt="Owl Cafe" class="img-fluid rounded" style="box-shadow: var(--shadow-lg);">
        </div>
    </div>
</section>

<!-- Mission & Vision -->
<section class="container py-5">
    <div class="row">
        <div class="col-md-6 mb-4 glass-card">
            <h3>Our Mission</h3>
            <p>To provide an unforgettable culinary experience by combining authentic flavors, innovative techniques, and warm hospitality in an elegant setting.</p>
        </div>
        <div class="col-md-6 mb-4 glass-card">
            <h3>Our Vision</h3>
            <p>To be the premier restaurant destination in the region, recognized for culinary innovation, exceptional service, and creating lasting memories for every guest.</p>
        </div>
    </div>
</section>

<!-- Chef Section -->
<section class="container py-5">
    <div class="section-title">
        <h2>Meet Our Chef</h2>
        <div class="accent-line mx-auto"></div>
    </div>

    <div class="row">
        <div class="col-md-4 text-center mb-4">
            <img src="/images/chef-placeholder.jpg" alt="Chef" class="img-fluid rounded-circle mb-3" style="width: 200px; height: 200px; object-fit: cover;">
        </div>
        <div class="col-md-8">
            <h3>Chef Marco Rossi</h3>
            <p class="text-accent mb-3">Executive Chef with 25+ years of experience</p>
            <p>Chef Marco brings decades of international culinary expertise to Owl Cafe. With training from prestigious institutions across Europe and Asia, he crafts dishes that blend traditional flavors with contemporary innovation.</p>
            <p>His passion for quality ingredients and culinary artistry is evident in every dish served at our restaurant.</p>
        </div>
    </div>
</section>

<!-- Statistics -->
<section class="container py-5" style="background-color: var(--cream-dark); border-radius: 20px; margin: 2rem 0; padding: 3rem 2rem;">
    <div class="row text-center">
        <div class="col-md-3 mb-3">
            <h3 class="text-accent" style="font-size: 2.5rem;">10+</h3>
            <p>Years of Excellence</p>
        </div>
        <div class="col-md-3 mb-3">
            <h3 class="text-accent" style="font-size: 2.5rem;">50K+</h3>
            <p>Happy Guests</p>
        </div>
        <div class="col-md-3 mb-3">
            <h3 class="text-accent" style="font-size: 2.5rem;">80+</h3>
            <p>Menu Items</p>
        </div>
        <div class="col-md-3 mb-3">
            <h3 class="text-accent" style="font-size: 2.5rem;">5?</h3>
            <p>Rating</p>
        </div>
    </div>
</section>

<!-- Values -->
<section class="container py-5">
    <div class="section-title">
        <h2>Our Values</h2>
        <div class="accent-line mx-auto"></div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="glass-card text-center">
                <i class="fas fa-leaf fa-3x text-accent mb-3"></i>
                <h4>Quality</h4>
                <p>Premium ingredients and meticulous preparation</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="glass-card text-center">
                <i class="fas fa-heart fa-3x text-accent mb-3"></i>
                <h4>Passion</h4>
                <p>Dedication to culinary excellence and guest satisfaction</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="glass-card text-center">
                <i class="fas fa-handshake fa-3x text-accent mb-3"></i>
                <h4>Integrity</h4>
                <p>Honest practices and transparent relationships</p>
            </div>
        </div>
    </div>
</section>
