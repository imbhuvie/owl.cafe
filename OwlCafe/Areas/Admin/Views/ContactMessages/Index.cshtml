@model IEnumerable<OwlCafe.Models.ContactMessage>

@{
    ViewData["Title"] = "Contact Messages";
}

<h5 class="mb-4">Contact Messages</h5>

<div class="admin-card p-4">
    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Subject</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var message in Model)
                    {
                        <tr>
                            <td><strong>@message.Name</strong></td>
                            <td>@message.Email</td>
                            <td>@message.Subject</td>
                            <td>@message.CreatedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="badge bg-@(message.IsRead ? "secondary" : "primary")">
                                    @(message.IsRead ? "Read" : "Unread")
                                </span>
                            </td>
                            <td>
                                <a href="@Url.Action("Details", "ContactMessages", new { area = "Admin", id = message.Id })" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <form method="post" action="@Url.Action("Delete", "ContactMessages", new { area = "Admin" })" style="display:inline;">
                                    <input type="hidden" name="id" value="@message.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No messages found.</p>
    }
</div>
