@model OwlCafe.Models.MenuItem

@{
    ViewData["Title"] = "Menu Item Details";
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0">@Model.Name</h5>
        <div>
            <a href="@Url.Action("Edit", "MenuItems", new { area = "Admin", id = Model.Id })" class="btn btn-warning btn-sm">
                <i class="fas fa-edit me-1"></i> Edit
            </a>
            <a href="@Url.Action("Index", "MenuItems", new { area = "Admin" })" class="btn btn-secondary btn-sm">Back</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-5">
            @if (!string.IsNullOrWhiteSpace(Model.Image))
            {
                <img src="@Model.Image" alt="@Model.Name" class="img-fluid rounded" style="width: 100%; max-height: 360px; object-fit: cover;">
            }
            else
            {
                <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 280px;">
                    <span class="text-muted">No image added</span>
                </div>
            }
        </div>
        <div class="col-md-7">
            <dl class="row">
                <dt class="col-sm-4">Category</dt>
                <dd class="col-sm-8">@(Model.Category?.Name ?? "Uncategorized")</dd>

                <dt class="col-sm-4">Price</dt>
                <dd class="col-sm-8">
                    @if (Model.DiscountPrice.HasValue)
                    {
                        <span>@Model.DiscountPrice.Value.ToRupees()</span>
                        <span class="text-muted text-decoration-line-through ms-2">@Model.Price.ToRupees()</span>
                    }
                    else
                    {
                        <span>@Model.Price.ToRupees()</span>
                    }
                </dd>

                <dt class="col-sm-4">Type</dt>
                <dd class="col-sm-8">@(Model.IsVeg ? "Vegetarian" : "Non-Vegetarian")</dd>

                <dt class="col-sm-4">Preparation</dt>
                <dd class="col-sm-8">@(Model.PreparationTime > 0 ? $"{Model.PreparationTime} minutes" : "Not set")</dd>

                <dt class="col-sm-4">Available</dt>
                <dd class="col-sm-8">@(Model.IsAvailable ? "Yes" : "No")</dd>

                <dt class="col-sm-4">Featured</dt>
                <dd class="col-sm-8">@(Model.IsFeatured ? "Yes" : "No")</dd>

                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8">@(Model.Status ? "Active" : "Inactive")</dd>

                <dt class="col-sm-4">Description</dt>
                <dd class="col-sm-8">@Model.Description</dd>
            </dl>
        </div>
    </div>
</div>
