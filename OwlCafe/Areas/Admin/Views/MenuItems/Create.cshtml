@model OwlCafe.Models.MenuItem

@{
    var modelId = Model?.Id ?? 0;
    ViewData["Title"] = modelId == 0 ? "Create Menu Item" : "Edit Menu Item";
}

<div class="admin-card p-4" style="max-width: 700px;">
    <h5 class="mb-4">@ViewData["Title"]</h5>

    <form method="post" enctype="multipart/form-data" action="@(modelId == 0 ? Url.Action("Create", "MenuItems", new { area = "Admin" }) : Url.Action("Edit", "MenuItems", new { area = "Admin", id = modelId }))">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label for="Name">Name</label>
                    <input type="text" class="form-control" id="Name" name="Name" value="@Model?.Name" required>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label for="CategoryId">Category</label>
                    <select class="form-control" id="CategoryId" name="CategoryId" required>
                        <option value="">Select Category</option>
                        @if (ViewData["Categories"] is IEnumerable<OwlCafe.Models.Category> categories)
                        {
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id" selected="@(Model?.CategoryId == cat.Id)">@cat.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="form-group mb-3">
            <label for="Description">Description</label>
            <textarea class="form-control" id="Description" name="Description" rows="3">@Model?.Description</textarea>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label for="Price">Price (INR)</label>
                    <input type="number" class="form-control" id="Price" name="Price" step="0.01" value="@Model?.Price" required>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label for="DiscountPrice">Discount Price (INR)</label>
                    <input type="number" class="form-control" id="DiscountPrice" name="DiscountPrice" step="0.01" value="@Model?.DiscountPrice">
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label for="Image">Image URL or Path</label>
                    <input type="text" class="form-control" id="Image" name="Image" maxlength="255" value="@Model?.Image" placeholder="https://example.com/image.jpg or /images/menu/dish.jpg">
                    <small class="text-muted">Paste an image URL/path or upload a file below.</small>
                    <span asp-validation-for="Image" class="text-danger d-block"></span>
                </div>
                <div class="form-group mb-3">
                    <label for="imageFile">Upload Image</label>
                    <input type="file" class="form-control" id="imageFile" name="imageFile" accept="image/*">
                    @if (!string.IsNullOrWhiteSpace(Model?.Image))
                    {
                        <img src="@Model.Image" alt="@Model.Name" class="mt-2 rounded" style="width: 120px; height: 80px; object-fit: cover;">
                    }
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label for="PreparationTime">Preparation Time (mins)</label>
                    <input type="number" class="form-control" id="PreparationTime" name="PreparationTime" value="@Model?.PreparationTime">
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label for="DisplayOrder">Display Order</label>
                    <input type="number" class="form-control" id="DisplayOrder" name="DisplayOrder" value="@Model?.DisplayOrder">
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label for="IsVeg">Type</label>
                    <select class="form-control" id="IsVeg" name="IsVeg">
                        <option value="true" selected="@(Model?.IsVeg == true)">Vegetarian</option>
                        <option value="false" selected="@(Model?.IsVeg == false)">Non-Vegetarian</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="IsAvailable" name="IsAvailable" value="true" @(Model?.IsAvailable == true ? "checked" : "")>
                    <label class="form-check-label" for="IsAvailable">
                        Available
                    </label>
                    <input type="hidden" name="IsAvailable" value="false">
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="IsFeatured" name="IsFeatured" value="true" @(Model?.IsFeatured == true ? "checked" : "")>
                    <label class="form-check-label" for="IsFeatured">
                        Featured
                    </label>
                    <input type="hidden" name="IsFeatured" value="false">
                </div>
            </div>
        </div>

        <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" id="Status" name="Status" value="true" @(Model?.Status == true ? "checked" : "")>
            <label class="form-check-label" for="Status">
                Active
            </label>
            <input type="hidden" name="Status" value="false">
        </div>

        @if (modelId > 0)
        {
            <input type="hidden" name="Id" value="@modelId" />
        }

        <div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="@Url.Action("Index", "MenuItems", new { area = "Admin" })" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
