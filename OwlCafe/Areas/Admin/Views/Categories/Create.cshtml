@model OwlCafe.Models.Category

@{
    var modelId = Model?.Id ?? 0;
    ViewData["Title"] = modelId == 0 ? "Create Category" : "Edit Category";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="admin-card p-4" style="max-width: 600px;">
    <h5 class="mb-4">@ViewData["Title"]</h5>

    <form method="post" action="@(modelId == 0 ? Url.Action("Create", "Categories", new { area = "Admin" }) : Url.Action("Edit", "Categories", new { area = "Admin", id = modelId }))">
        @Html.AntiForgeryToken()
        <div class="form-group mb-3">
            <label for="Name">Name</label>
            <input type="text" class="form-control" id="Name" name="Name" value="@Model?.Name" required>
        </div>

        <div class="form-group mb-3">
            <label for="Description">Description</label>
            <textarea class="form-control" id="Description" name="Description" rows="4">@Model?.Description</textarea>
        </div>

        <div class="form-group mb-3">
            <label for="DisplayOrder">Display Order</label>
            <input type="number" class="form-control" id="DisplayOrder" name="DisplayOrder" value="@Model?.DisplayOrder">
        </div>

        <div class="form-group mb-3">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="Status" name="Status" @(Model?.Status == true ? "checked" : "")>
                <label class="form-check-label" for="Status">
                    Active
                </label>
            </div>
        </div>

        @if (modelId > 0)
        {
            <input type="hidden" name="Id" value="@modelId" />
        }

        <div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="@Url.Action("Index", "Categories", new { area = "Admin" })" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
