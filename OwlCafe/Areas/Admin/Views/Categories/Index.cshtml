@model IEnumerable<OwlCafe.Models.Category>

@{
    ViewData["Title"] = "Categories Management";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5>Categories</h5>
    <a href="@Url.Action("Create", "Categories", new { area = "Admin" })" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i> Add Category
    </a>
</div>

<div class="admin-card p-4">
    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Order</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model.OrderBy(c => c.DisplayOrder))
                    {
                        <tr>
                            <td><strong>@category.Name</strong></td>
                            <td>@(category.Description.Length > 50 ? category.Description.Substring(0, 50) + "..." : category.Description)</td>
                            <td>@category.DisplayOrder</td>
                            <td>
                                <span class="badge bg-@(category.Status ? "success" : "danger")">
                                    @(category.Status ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <a href="@Url.Action("Edit", "Categories", new { area = "Admin", id = category.Id })" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="@Url.Action("Delete", "Categories", new { area = "Admin" })" style="display:inline;">
                                    <input type="hidden" name="id" value="@category.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No categories found. <a href="@Url.Action("Create", "Categories", new { area = "Admin" })">Create one</a></p>
    }
</div>
