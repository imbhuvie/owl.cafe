@model OwlCafe.Models.Booking

@{
    ViewData["Title"] = "Edit Booking";
}

<div class="admin-card p-4" style="max-width: 700px;">
    <h5 class="mb-4">Edit Booking</h5>

    <form method="post">
        @Html.AntiForgeryToken()
        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label>Customer Name</label>
                    <input type="text" class="form-control" value="@Model?.CustomerName" disabled>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label>Email</label>
                    <input type="email" class="form-control" value="@Model?.Email" disabled>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label>Phone</label>
                    <input type="tel" class="form-control" value="@Model?.Phone" disabled>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label>Guests</label>
                    <input type="number" class="form-control" value="@Model?.Guests" disabled>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label>Date</label>
                    <input type="date" class="form-control" value="@Model?.BookingDate.ToString("yyyy-MM-dd")" disabled>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label>Time</label>
                    <input type="time" class="form-control" value="@Model?.BookingTime.ToString("hh\\:mm")" disabled>
                </div>
            </div>
        </div>

        <div class="form-group mb-3">
            <label for="TableId">Assign Table</label>
            <select class="form-control" id="TableId" name="TableId">
                <option value="">Not Assigned</option>
                @if (ViewData["Tables"] is IEnumerable<OwlCafe.Models.RestaurantTable> tables)
                {
                    @foreach (var table in tables)
                    {
                        <option value="@table.Id" selected="@(Model?.TableId == table.Id)">
                            Table @table.TableNumber - @table.Capacity Seats (@table.Location)
                        </option>
                    }
                }
            </select>
        </div>

        <div class="form-group mb-3">
            <label for="Status">Status</label>
            <select class="form-control" id="Status" name="Status">
                <option value="Pending" selected="@(Model?.Status == OwlCafe.Models.BookingStatus.Pending)">Pending</option>
                <option value="Approved" selected="@(Model?.Status == OwlCafe.Models.BookingStatus.Approved)">Approved</option>
                <option value="Rejected" selected="@(Model?.Status == OwlCafe.Models.BookingStatus.Rejected)">Rejected</option>
                <option value="Completed" selected="@(Model?.Status == OwlCafe.Models.BookingStatus.Completed)">Completed</option>
                <option value="Cancelled" selected="@(Model?.Status == OwlCafe.Models.BookingStatus.Cancelled)">Cancelled</option>
            </select>
        </div>

        <div class="form-group mb-3">
            <label for="SpecialRequest">Special Request</label>
            <textarea class="form-control" id="SpecialRequest" name="SpecialRequest" rows="3">@Model?.SpecialRequest</textarea>
        </div>

        <input type="hidden" name="Id" value="@Model?.Id" />

        <div>
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="@Url.Action("Index", "Bookings", new { area = "Admin" })" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
