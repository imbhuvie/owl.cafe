@model OwlCafe.Models.RestaurantTable

@{
    var modelId = Model?.Id ?? 0;
    ViewData["Title"] = modelId == 0 ? "Create Table" : "Edit Table";
}

<div class="admin-card p-4" style="max-width: 600px;">
    <h5 class="mb-4">@ViewData["Title"]</h5>

    <form method="post">
        @Html.AntiForgeryToken()
        <div class="form-group mb-3">
            <label for="TableNumber">Table Number</label>
            <input type="number" class="form-control" id="TableNumber" name="TableNumber" value="@Model?.TableNumber" required>
        </div>

        <div class="form-group mb-3">
            <label for="Capacity">Capacity (Guests)</label>
            <input type="number" class="form-control" id="Capacity" name="Capacity" value="@Model?.Capacity" required>
        </div>

        <div class="form-group mb-3">
            <label for="Location">Location</label>
            <input type="text" class="form-control" id="Location" name="Location" placeholder="e.g., Section A, Window View" value="@Model?.Location" required>
        </div>

        <div class="form-group mb-3">
            <label for="Status">Status</label>
            <select class="form-control" id="Status" name="Status">
                <option value="Available" selected="@(Model?.Status == OwlCafe.Models.TableStatus.Available)">Available</option>
                <option value="Reserved" selected="@(Model?.Status == OwlCafe.Models.TableStatus.Reserved)">Reserved</option>
                <option value="Maintenance" selected="@(Model?.Status == OwlCafe.Models.TableStatus.Maintenance)">Maintenance</option>
            </select>
        </div>

        @if (modelId > 0)
        {
            <input type="hidden" name="Id" value="@modelId" />
        }

        <div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="@Url.Action("Index", "Tables", new { area = "Admin" })" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
