@model IEnumerable<OwlCafe.Models.RestaurantTable>

@{
    ViewData["Title"] = "Tables Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5>Restaurant Tables</h5>
    <a href="@Url.Action("Create", "Tables", new { area = "Admin" })" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i> Add Table
    </a>
</div>

<div class="admin-card p-4">
    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Table No.</th>
                        <th>Capacity</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var table in Model)
                    {
                        <tr>
                            <td><strong>@table.TableNumber</strong></td>
                            <td>@table.Capacity persons</td>
                            <td>@table.Location</td>
                            <td>
                                <span class="badge bg-@(table.Status == OwlCafe.Models.TableStatus.Available ? "success" : table.Status == OwlCafe.Models.TableStatus.Reserved ? "warning" : "danger")">
                                    @table.Status
                                </span>
                            </td>
                            <td>
                                <a href="@Url.Action("Edit", "Tables", new { area = "Admin", id = table.Id })" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="@Url.Action("Delete", "Tables", new { area = "Admin" })" style="display:inline;">
                                    <input type="hidden" name="id" value="@table.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No tables found.</p>
    }
</div>
